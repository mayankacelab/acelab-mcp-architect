# Example environment variables
# Copy this to .env and update with your values

# Required: OAuth token for acelab API
OAUTH_TOKEN=your_oauth_token_here

# Optional: API base URL (defaults to acelab dev environment)
API_BASE_URL=https://acelab-api-dev-pod-5-vnhmkx7udq-uk.a.run.app/api

# Optional: Server port (defaults to 3000)
PORT=3000

# Optional: CORS origins (comma-separated, defaults to *)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: Log level (defaults to info)
LOG_LEVEL=info